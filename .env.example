# Copy to `.env` and adjust. docker compose reads this automatically.

# Registry image reference for remote (registry) deploys — your GHCR repo.
# OWNER is your GitHub username/org, lowercase.
VMT_IMAGE=ghcr.io/OWNER/vmt:latest

# Host port to publish the app's HTTP port (8080) on. Point your reverse proxy
# / TLS terminator for vmt.int.paulandjenn.com at this.
VMT_HTTP_PORT=8080
# Interface to bind the published port to. Use 127.0.0.1 when the reverse proxy
# runs on the same host (keeps the app off public interfaces); 0.0.0.0 exposes
# it on all interfaces.
VMT_BIND_ADDR=127.0.0.1

# Initial admin password, applied only on first startup (when none is set yet).
# If left blank, you'll set the password through the web UI on first visit.
VMT_ADMIN_PASSWORD=

# Display preferences.
VMT_CURRENCY=$
VMT_DISTANCE_UNIT=mi
VMT_DATE_FORMAT=Jan 2, 2006

# Timezone for date handling/logs.
TZ=UTC

# Public base URL of the app (used for links in notification emails).
VMT_BASE_URL=https://vmt.int.paulandjenn.com

# Outbound email for reminder notifications. Leave VMT_SMTP_HOST blank to disable.
#   VMT_SMTP_TLS: starttls (port 587, default) | implicit (port 465) | none
VMT_SMTP_HOST=
VMT_SMTP_PORT=587
VMT_SMTP_USER=
VMT_SMTP_PASS=
VMT_SMTP_FROM=
VMT_SMTP_TLS=starttls
